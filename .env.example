# App
NODE_ENV=development
PORT=8000
BASE_URL=http://localhost:8000

# Web (Next.js) -> API tRPC endpoint
NEXT_PUBLIC_API_URL=http://localhost:8000/trpc

# Database (matches docker-compose.yml: user/pass=postgres, db=dev)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/dev

# Google OAuth (leave empty to disable Google login; fill in to enable)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/authentication/google/callback
